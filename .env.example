# ──────────────────────────────────────────────────────────
# Workflow Engine — environment configuration
# Copy to .env for local development: cp .env.example .env
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=disable
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workflow-engine?sslmode=disable

# ── Optional: HTTP server ─────────────────────────────────

# TCP address the API server listens on. Defaults to :8080.
# HTTP_ADDR=:8080

# ── Optional: Swagger UI ──────────────────────────────────

# Set to "true" to mount the Swagger UI at /swagger/.
# Defaults to false in production; safe to enable locally.
# ENABLE_SWAGGER=true

# ── Optional: CORS ───────────────────────────────────────

# Comma-separated list of allowed origins for CORS.
# ALLOWED_ORIGINS=http://localhost:5173

# ── Optional: Event Streaming integration ────────────────

# Base URL of the Atlas Event Streaming API.
# When set, workflow lifecycle events are published to the event store.
# EVENT_STREAMING_BASE_URL=http://localhost:8082

# API token for the Event Streaming service.
# EVENT_STREAMING_API_TOKEN=dev-api-key

# ── Optional: Kafka consumer (event-driven triggers) ──────

# Comma-separated list of Kafka broker addresses.
# When set together with KAFKA_EVENTS_TOPIC, the engine subscribes to
# integration events and triggers workflows via registered event triggers.
# KAFKA_BROKERS=localhost:9092

# Kafka topic that carries integration events.
# KAFKA_EVENTS_TOPIC=events.v1

# Kafka consumer group ID. Defaults to "workflow-engine".
# KAFKA_CONSUMER_GROUP=workflow-engine

# ── Optional: Demo mode ───────────────────────────────────

# When DEMO_MODE=true a fixed project and API key are pre-seeded so the
# system can be exercised without a full tenant provisioning flow.
# DEMO_MODE=false
# DEMO_API_KEY=atlas-demo-key
# DEMO_PROJECT_ID=c0000000-0000-0000-0000-000000000001
